// ============================================================================
// RISC-V RV32I — Bubble Sort (n=8) - Back-edge Version
// ============================================================================

@00001000
// ── Branch A: Outer Loop Header ──────────────────────────────────────────
00000293  // 0x1000  addi  t0, x0, 0       i = 0
FFF58393  // 0x1004  addi  t2, a1, -1      t2 = n-1

// ── inner_loop_init ──────────────────────────────────────────────────────
40538E33  // 0x1008  sub   t3, t2, t0      t3 = n-1-i
00000313  // 0x100C  addi  t1, x0, 0       j = 0

// ── Branch B: Inner Loop Body ────────────────────────────────────────────
00231E93  // 0x1010  slli  t4, t1, 2       t4 = j * 4
01D50EB3  // 0x1014  add   t4, a0, t4      t4 = &a[j]
000EAF03  // 0x1018  lw    t5, 0(t4)       t5 = a[j]
004EAF83  // 0x101C  lw    t6, 4(t4)       t6 = a[j+1]

// ── Branch C: Swap Condition (PC 0x1020) ─────────────────────────────────
005F5663  // 0x1020  bge   t5, t6, 0x102C  Branch C: Skip swap if a[j] <= a[j+1]
01FEA023  // 0x1024  sw    t6, 0(t4)       swap...
01EEA223  // 0x1028  sw    t5, 4(t4)

// ── Increment and Inner Loop Back-edge ───────────────────────────────────
00130313  // 0x102C  addi  t1, t1, 1       j++
FCD346E3  // 0x1030  blt   t1, t3, 0x1010  Branch B: Jump back if j < t3 (TAKEN)

// ── Increment and Outer Loop Back-edge ───────────────────────────────────
00128293  // 0x1034  addi  t0, t0, 1       i++
FCE2CE63  // 0x1038  blt   t0, t2, 0x1008  Branch A: Jump back if i < t2 (TAKEN)

00008067  // 0x103C  jalr  x0, ra, 0       return
